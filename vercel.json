{
  "version": 2,
  "functions": {
    "src/api/chat.js": { "maxDuration": 60 },
    "src/api/task.js": { "maxDuration": 60 }
  },
  "routes": [
    { "src": "/api/chat",      "dest": "/src/api/chat.js" },
    { "src": "/api/task/(.*)", "dest": "/src/api/task.js" },
    { "src": "/api/task",      "dest": "/src/api/task.js" },
    { "src": "/(.*)",          "dest": "/public/$1"       }
  ]
}
