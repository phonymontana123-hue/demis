{
  "version": 2,
  "functions": {
    "api/chat.js": { "maxDuration": 60 },
    "api/task.js": { "maxDuration": 60 }
  },
  "routes": [
    { "src": "/api/chat",      "dest": "/api/chat.js" },
    { "src": "/api/task/(.*)", "dest": "/api/task.js" },
    { "src": "/api/task",      "dest": "/api/task.js" },
    { "src": "/(.*)",          "dest": "/public/$1"   }
  ]
}
